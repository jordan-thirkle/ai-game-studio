# Environment Variables for ai-game-studio (Eigen)

# ─── Required ────────────────────────────────────────────
# No required API keys — the app works with static data.
# Game content is defined in src/data/games.ts, not fetched from APIs.

# ─── Optional: Asset Generation ──────────────────────────
# Uncomment these if you want to use asset generation scripts

# Gemini — Image generation for game assets
# GOOGLE_API_KEY=your_google_api_key_here

# Tripo — 3D model generation
# TRIPO_API_KEY=your_tripo_api_key_here

# ElevenLabs — Audio generation
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ─── Optional: Development ───────────────────────────────
# Vercel deployment (if using CLI)
# VERCEL_ORG_ID=your_vercel_org_id
# VERCEL_PROJECT_ID=your_vercel_project_id

# OpenRouter (used by Hermes proxy, not the app itself)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Merge Gateway API key (used by merge-gateway-proxy, not the app)
# MERGE_GATEWAY_API_KEY=mg_your_key_here
